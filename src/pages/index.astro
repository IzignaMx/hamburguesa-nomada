---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Hero from "../components/Hero.astro";
import Announcement from "../components/Announcement.astro";
import Categories from "../components/Categories.astro";
import LineupTimeline from "../components/LineupTimeline.astro";
import SponsorsGrid from "../components/SponsorsGrid.astro";
import PrizeCallout from "../components/PrizeCallout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import sponsors from "../data/sponsors.json";
import copy from "../data/official-copy.json";
---

<BaseLayout
  title="Hamburguesa Nómada — Aniversario 5"
  description="Alleycat, convivencia, categorías, DJS, colaboradorxs y premios."
>
  <SiteHeader />
  <Hero />

  <main id="main">
    <Announcement />

    <Categories />

    <LineupTimeline />

    <section id="colaboradores" class="section">
      <div class="container">
        <h2>{copy.collaborators.title}</h2>
        <SponsorsGrid sponsors={sponsors} />
      </div>
    </section>

    <PrizeCallout />
  </main>

  <SiteFooter />
</BaseLayout>
