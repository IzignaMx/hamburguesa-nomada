---
import type { Sponsor } from "../lib/types";

interface Props {
  sponsors: Sponsor[];
}

const { sponsors } = Astro.props;

const hasPublicName = (sponsor: Sponsor): boolean =>
  sponsor.identificationConfidence !== "unknown" &&
  !sponsor.id.startsWith("colaboracion-temporal-") &&
  !/^Colaboración temporal\s+\d+$/i.test(sponsor.name);
---

<div class="sponsor-grid">
  {
    sponsors.map((sponsor) => {
      const isNamed = hasPublicName(sponsor);

      return (
      <article class:list={["sponsor-card", !isNamed && "sponsor-card--unnamed"]}>
        <img
          src={sponsor.logo}
          alt={isNamed ? `Logotipo de ${sponsor.name}` : ""}
          loading="lazy"
          width="240"
          height="240"
        />
        {isNamed && <h3>{sponsor.name}</h3>}
        {isNamed && sponsor.url && (
          <a href={sponsor.url} target="_blank" rel="noopener noreferrer">
            Visitar
          </a>
        )}
      </article>
      );
    })
  }
</div>
