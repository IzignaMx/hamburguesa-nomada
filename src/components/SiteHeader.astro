---
/**
 * SiteHeader — navegación sticky con botón móvil semántico
 *
 *   - Logo + nav en escritorio
 *   - Menú móvil controlado por navigation.ts
 *   - Smooth scroll a secciones
 */

import brandLogo from "../assets/brand/hamburguesa-nomada-logo.webp";
import { Image } from "astro:assets";
---

<header class="site-header">
  <div class="site-header__inner container">
    <a href="/" class="site-header__logo-link" aria-label="Ir al inicio de Hamburguesa Nómada">
      <Image
        class="site-header__logo"
        src={brandLogo}
        alt=""
        widths={[36, 72]}
        sizes="36px"
        quality={60}
        loading="eager"
        decoding="async"
      />
      <span class="site-header__wordmark">Hamburguesa Nómada</span>
    </a>

    <button
      class="nav-btn"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Abrir menú de navegación"
    >
      <span class="nav-btn__line"></span>
      <span class="nav-btn__line"></span>
      <span class="nav-btn__line"></span>
    </button>

    <nav id="site-nav" class="site-header__nav" aria-label="Navegación principal">
      <a href="#comunicado">Comunicado</a>
      <a href="#categorias">Categorías</a>
      <a href="#djs">DJS</a>
      <a href="#colaboradores">Colaboradorxs</a>
      <a href="/resultados/">Resultados</a>
      <a href="/galeria/">Galería</a>
      <a href="/premios/">Premios</a>
      <a
        class="nav-whatsapp"
        href="https://wa.me/525578362426"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
      ></a>
    </nav>
  </div>
</header>

<script>
  import "../scripts/navigation";
</script>
