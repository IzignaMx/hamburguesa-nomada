---
import copy from "../data/official-copy.json";
import Countdown from "./Countdown.astro";
import EventFacts from "./EventFacts.astro";
import HeroPosterArt from "./HeroPosterArt.astro";
---

<div class="hero" id="hero">
  <div class="hero__inner container">
    <div class="hero__brand">
      <img
        class="hero__logo"
        src="/logos/hamburguesa-nomada.webp"
        alt=""
        width="140"
        height="140"
        fetchpriority="high"
      />
      <p class="eyebrow hero__anniversary">{copy.hero.anniversary}</p>
      <h1 class="hero__title">{copy.hero.event}</h1>

      <Countdown />

      <EventFacts />

      <div class="hero__actions actions">
        <a class="button" href="#comunicado">COMUNICADO</a>
        <a class="button button--ghost" href="/premios/">PREMIOS</a>
      </div>
    </div>

    <HeroPosterArt />
  </div>
</div>

<script>
  import "../scripts/parallax";
</script>
